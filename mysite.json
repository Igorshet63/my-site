{
  "theme": {
    "name": "Нейросинтез (Neural Synthesis)",
    "mode": "dark",
    "concept": "Dark mode для разработчиков с акцентом на AI и технологии"
  },
  "color": {
    "deep_code": {
      "hex": "#0B1120",
      "usage": "60% — Основной фон сайта",
      "description": "Глубокий темно-синий, VS Code dark theme vibe"
    },
    "obsidian_glass": {
      "hex": "#151D2E",
      "usage": "30% — Карточки, бейджи, границы",
      "description": "Glassmorphism эффект, элевейшн"
    },
    "clean_syntax": {
      "hex": "#E2E8F0",
      "usage": "30% — Основной текст (H1, H2, абзацы)",
      "description": "Мягкий серебристо-белый, WCAG AAA контраст"
    },
    "ai_spark": {
      "hex": "#00E5FF",
      "usage": "10% — Акценты, CTA, подсветка",
      "description": "Пронзительный циан, ассоциация с AI и технологиями"
    },
    "semantic": {
      "background": "#0B1120",
      "surface": "#151D2E",
      "text_primary": "#E2E8F0",
      "text_secondary": "#94a3b8",
      "accent": "#00E5FF",
      "success": "#10b981",
      "border": "rgba(0, 229, 255, 0.15)"
    }
  },
  "typography": {
    "fonts": {
      "primary": "Inter",
      "display": "Space Grotesk",
      "fallback": "system-ui, sans-serif"
    },
    "heading": {
      "fontFamily": "Space Grotesk, sans-serif",
      "fontWeight": "700",
      "fontSize": "64px",
      "lineHeight": "1.1",
      "letterSpacing": "-2px",
      "color": "#E2E8F0"
    },
    "subheading": {
      "fontFamily": "Space Grotesk, sans-serif",
      "fontWeight": "400",
      "fontSize": "28px",
      "lineHeight": "1.3",
      "color": "#94a3b8"
    },
    "body": {
      "fontFamily": "Inter, sans-serif",
      "fontWeight": "300",
      "fontSize": "18px",
      "lineHeight": "1.7",
      "color": "#94a3b8"
    },
    "button": {
      "fontFamily": "Inter, sans-serif",
      "fontWeight": "500",
      "fontSize": "16px",
      "lineHeight": "1.5",
      "letterSpacing": "0"
    },
    "badge": {
      "fontFamily": "Space Grotesk, sans-serif",
      "fontWeight": "500",
      "fontSize": "14px",
      "letterSpacing": "0.5px",
      "textTransform": "uppercase"
    }
  },
  "effects": {
    "glow": {
      "ai_spark": "0 0 20px rgba(0, 229, 255, 0.3)",
      "ai_spark_strong": "0 0 30px rgba(0, 229, 255, 0.5)",
      "success": "0 0 10px rgba(16, 185, 129, 0.5)"
    },
    "shadows": {
      "card": "0 8px 32px rgba(0, 0, 0, 0.4)",
      "soft": "0 4px 20px rgba(0, 0, 0, 0.3)",
      "elevated": "0 20px 50px rgba(0, 0, 0, 0.5)"
    },
    "gradients": {
      "neural_radial": "radial-gradient(circle at 50% 0%, rgba(0, 229, 255, 0.08) 0%, transparent 50%)",
      "card_surface": "linear-gradient(145deg, rgba(21, 29, 46, 0.9) 0%, rgba(15, 23, 42, 0.95) 100%)",
      "text_accent": "linear-gradient(135deg, #00E5FF 0%, #E2E8F0 100%)"
    },
    "backdrop": {
      "glass": "blur(20px)"
    },
    "animations": {
      "pulse": "pulse 4s ease-in-out infinite",
      "float": "float 6s ease-in-out infinite",
      "blink": "blink 2s ease-in-out infinite"
    }
  },
  "spacing": {
    "xs": "8px",
    "sm": "12px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "xxl": "48px",
    "xxxl": "64px"
  },
  "radius": {
    "sm": "6px",
    "md": "12px",
    "lg": "16px",
    "xl": "24px",
    "full": "9999px"
  },
  "components": {
    "button_primary": {
      "background": "#00E5FF",
      "color": "#0B1120",
      "shadow_hover": "0 0 30px rgba(0, 229, 255, 0.3), 0 10px 40px rgba(0, 229, 255, 0.2)",
      "transform_hover": "translateY(-2px)"
    },
    "button_secondary": {
      "background": "transparent",
      "border": "1px solid #1e293b",
      "color": "#E2E8F0",
      "border_hover": "#00E5FF",
      "color_hover": "#00E5FF"
    },
    "card": {
      "background": "#151D2E",
      "border": "1px solid rgba(0, 229, 255, 0.15)",
      "shadow": "0 8px 32px rgba(0, 0, 0, 0.4)"
    },
    "badge": {
      "background": "#151D2E",
      "border": "1px solid rgba(0, 229, 255, 0.2)",
      "color": "#00E5FF"
    }
  },
  "layout": {
    "max_width": "1440px",
    "header_height": "80px",
    "hero_min_height": "100vh",
    "container_padding": "32px"
  }
}